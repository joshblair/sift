      "text": "// S3 key structure\nacme-corp/\n  doc-uuid-1/\n    report.pdf\nglobex-inc/\n  doc-uuid-2/\n    contract.docx",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "// S3 key structure\nacme-corp/\n  doc-uuid-1/\n    report.pdf\nglobex-inc/\n  doc-uuid-2/\n    contract.docx",
      "lineHeight": 1.25,
      "index": "aI",
      "autoResize": true
