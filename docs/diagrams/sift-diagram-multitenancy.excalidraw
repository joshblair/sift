      "link": null,
      "locked": false,
      "text": "A Pre-Token Generation\nLambda adds tenantId\nas a custom claim before\nCognito signs the JWT.\nUsers cannot forge it.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "containerId": null,
      "originalText": "A Pre-Token Generation\nLambda adds tenantId\nas a custom claim before\nCognito signs the JWT.\nUsers cannot forge it.",
      "lineHeight": 1.25,
      "index": "aB",
      "autoResize": true
    },
