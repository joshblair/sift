      "updated": 1779293736721,
      "link": null,
      "locked": false,
      "text": "// JWT payload\n{\n  \"sub\": \"user-uuid\",\n  \"custom:tenantId\":\n    \"acme-corp\",\n  \"email\": \"user@acme.com\"\n}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "// JWT payload\n{\n  \"sub\": \"user-uuid\",\n  \"custom:tenantId\":\n    \"acme-corp\",\n  \"email\": \"user@acme.com\"\n}",
      "lineHeight": 1.25,
      "index": "aD",
      "autoResize": true
    },
    {
      "id": "col1-guarantee",
      "type": "text",
      "x": 45,
      "y": 425,
      "width": 280,
      "height": 100,
      "angle": 0,
      "strokeColor": "#c2410c",
      "backgroundColor": "transparent",
