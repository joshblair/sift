      "updated": 1779293736721,
      "link": null,
      "locked": false,
      "text": "Every document is stored\nunder a key namespaced\nby tenantId. Presigned\nURLs are scoped to that\nprefix by the Lambda.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "containerId": null,
      "originalText": "Every document is stored\nunder a key namespaced\nby tenantId. Presigned\nURLs are scoped to that\nprefix by the Lambda.",
      "lineHeight": 1.25,
      "index": "aG",
      "autoResize": true
    },
