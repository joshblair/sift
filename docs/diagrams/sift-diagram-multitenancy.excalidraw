      "isDeleted": false,
      "boundElements": [],
      "updated": 1779293736721,
      "link": null,
      "locked": false,
      "text": "GUARANTEE\nAPI Gateway rejects\nrequests with no valid\nJWT. Lambda extracts\ntenantId from the\nvalidated token context.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "GUARANTEE\nAPI Gateway rejects\nrequests with no valid\nJWT. Lambda extracts\ntenantId from the\nvalidated token context.",
      "lineHeight": 1.25,
      "index": "aE",
      "autoResize": true
    },
